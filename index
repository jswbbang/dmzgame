    function updateUI() {
        document.getElementById("stat-peace").innerText = stats.peace;
        document.getElementById("stat-eco").innerText = stats.eco;
        document.getElementById("stat-economy").innerText = stats.economy;

        if (currentRoundId === "ending") {
            calculateFinalEnding();
            return;
        }

        const roundData = storyData[currentRoundId];
        document.getElementById("progress").innerText = "진행 라운드: " + turnCount + " / " + maxTurns;
        document.getElementById("story-title").innerText = roundData.title;
        document.getElementById("story-text").innerText = roundData.text;

        const kb = document.getElementById("knowledge-box");
        kb.innerText = "💡 지식 더하기: " + roundData.knowledge;
        kb.classList.remove("hidden");

        const choicesContainer = document.getElementById("choices-container");
        choicesContainer.innerHTML = ""; 

        roundData.choices.forEach(function(choice) {
            const btn = document.createElement("button");
            btn.className = "choice-btn";
            btn.innerText = choice.text;
            btn.onclick = function() { 
                if (choice.route) {
                    chosenRoute = choice.route;
                }
                selectChoice(choice.effect, choice.nextId); 
            };
            choicesContainer.appendChild(btn);
        });
    }

    function selectChoice(effect, nextId) {
        if (effect.peace) stats.peace += effect.peace;
        if (effect.eco) stats.eco += effect.eco;
        if (effect.economy) stats.economy += effect.economy;
        
        turnCount++;
        currentRoundId = nextId;
        updateUI();
    }

    function calculateFinalEnding() {
        let endingTitle = "";
        let endingText = "";

        let minStat = Math.min(stats.peace, stats.eco, stats.economy);

        // 히든 엔딩: 3가지 스탯이 고루 잘 분배되었을 때 (최소값이 일정 이상)
        if (minStat >= 5) {
            endingTitle = "엔딩 10. 🏆 세계를 감동시킨 노벨평화상 수상자 (히든 엔딩)";
            endingText = "평화를 사랑하는 마음, 자연을 아끼는 마음, 함께 잘살고자 하는 지혜를 완벽하게 조율해 낸 당신! 훌륭한 리더십 덕분에 DMZ는 세계 최고의 평화 상징이 되었고, 영광스러운 노벨평화상을 수상합니다.";
        } 
        else if (chosenRoute === "peace") {
            if (stats.peace >= 12) {
                endingTitle = "엔딩 1. 🕊️ UN 한반도 평화 특별대사";
                endingText = "모두가 서로를 이해하고 용서할 수 있도록 끊임없이 노력한 결과, UN 특별대사로 임명되었습니다. 당신의 따뜻한 외교력은 전 세계 분쟁 지역 어린이들에게 큰 희망이 됩니다.";
            } else if (stats.economy >= stats.eco) {
                endingTitle = "엔딩 2. 🤝 글로벌 평화 구호 재단 이사장";
                endingText = "어려운 이웃을 돕는 따뜻한 인도주의적 활동과 경제적 지원을 아끼지 않았습니다. 이념을 넘어 사람을 먼저 생각한 당신의 따뜻한 마음이 수많은 생명을 살리는 기적을 만들었습니다.";
            } else {
                endingTitle = "엔딩 3. 🌻 대성동 평화의 마을 촌장";
                endingText = "어느 한쪽에 치우치지 않고 이웃과 사이좋게 지내며 마을의 일상을 성실하게 지켜왔습니다. 매일매일 웃으며 인사하고 평화롭게 살아가는 평범한 일상이 곧 평화의 시작임을 몸소 보여줍니다.";
            }
        } 
        else if (chosenRoute === "econ") {
            if (stats.economy >= 12) {
                endingTitle = "엔딩 4. 🏙️ 한반도 미래 스마트 시티 총괄 시장";
                endingText = "모두가 풍요롭고 편리하게 살아갈 수 있는 최첨단 스마트 경제 특구를 멋지게 설계했습니다. 훌륭한 기술력으로 단절의 장벽을 시원하게 허물고 아시아의 중심을 만들었습니다.";
            } else if (stats.peace >= stats.eco) {
                endingTitle = "엔딩 5. 🚆 유라시아 횡단열차 1호 기관장";
                endingText = "오랜 시간 끊어져 있던 기찻길이 마침내 열렸습니다. 당신은 남북을 거쳐 넓은 유럽 대륙까지 사람들의 반가운 인사와 물건을 싣고 달리는 평화 열차의 첫 주인공이 되었습니다.";
            } else {
                endingTitle = "엔딩 6. 💼 친환경 남북 무역 회사 CEO";
                endingText = "자연을 훼손하지 않으면서도 지역 주민들이 함께 부자가 될 수 있는 훌륭한 친환경 제품을 개발했습니다. 경제 성장과 자연 보호 두 마리 토끼를 잡은 존경받는 기업인이 되었습니다.";
            }
        } 
        else if (chosenRoute === "eco") {
            if (stats.eco >= 12) {
                endingTitle = "엔딩 7. 🌿 세계자연보전연맹(IUCN) 최고 위원장";
                endingText = "당신의 헌신으로 DMZ는 곰과 두루미가 안전하게 뛰노는 생태 구역으로 영구 지정되었습니다. 전 세계 생태학자들이 한반도의 경이로운 자연을 배우기 위해 앞다투어 찾아옵니다.";
            } else if (stats.economy >= stats.peace) {
                endingTitle = "엔딩 8. 📸 글로벌 DMZ 생태 관광 센터장";
                endingText = "자연을 훼손하지 않으면서도 전 세계인들이 DMZ의 아름다움을 흠뻑 느낄 수 있는 멋진 생태 탐방 코스를 만들었습니다. 훌륭한 관광 프로그램으로 마을 주민들에게도 큰 행복을 주었습니다.";
            } else {
                endingTitle = "엔딩 9. 🦌 국가 지정 야생동물 특별 구조대장";
                endingText = "다친 야생동물들을 치료하고 따뜻하게 돌보아 자연으로 돌려보내는 훌륭한 시스템을 구축했습니다. 사람과 동물이 조화롭게 살아가는 방법을 제시한 멋진 환경 선생님으로 역사에 남습니다.";
            }
        }

        showEnding(endingTitle, endingText);
    }

    function showEnding(title, text) {
        document.getElementById("progress").innerText = "게임 종료 - 결과 창";
        document.getElementById("story-title").innerText = title;
        document.getElementById("story-text").innerText = text;
        
        let finalAnalysis = "<br><br>[최종 나의 성향 분석]<br>";
        finalAnalysis += "🕊️ 평화 기여도: " + stats.peace + " | 🌿 생태 보존: " + stats.eco + " | 💰 경제 가치: " + stats.economy;
        document.getElementById("story-text").innerHTML += finalAnalysis;

        document.getElementById("knowledge-box").classList.add("hidden");
        document.getElementById("choices-container").innerHTML = 
            "<button class=\"choice-btn ending-btn\" onclick=\"location.reload()\">🎮 다시 플레이하기</button>";
    }

    updateUI();
</script>

