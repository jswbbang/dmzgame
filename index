<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DMZ, 미래를 향한 나의 선택</title>
    <style>
        body {
            font-family: "Malgun Gothic", "Apple SD Gothic Neo", sans-serif;
            background-color: #f0f4f8;
            color: #333;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            box-sizing: border-box;
        }
        #game-container {
            background: white;
            width: 800px;
            max-width: 100%;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 40px;
            text-align: center;
            position: relative;
        }
        #status-bar {
            display: flex;
            justify-content: space-between;
            background: #e9ecef;
            padding: 15px 20px;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .stat-item {
            background: white;
            padding: 5px 15px;
            border-radius: 20px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }
        #progress {
            font-size: 0.9rem;
            color: #777;
            margin-bottom: 15px;
            text-align: left;
            font-weight: bold;
        }
        #story-title {
            color: #2c3e50;
            margin-bottom: 15px;
            font-size: 1.6rem;
        }
        #story-text {
            font-size: 1.15rem;
            line-height: 1.7;
            margin-bottom: 25px;
            text-align: left;
            background: #fafafa;
            padding: 25px;
            border-left: 6px solid #4a90e2;
            border-radius: 8px;
            word-break: keep-all;
        }
        #knowledge-box {
            font-size: 1rem;
            color: #555;
            background: #fff8e1;
            padding: 20px;
            border-radius: 8px;
            margin-bottom: 30px;
            text-align: left;
            border: 1px solid #ffe082;
            line-height: 1.6;
        }
        .choice-btn {
            display: block;
            width: 100%;
            background: #4a90e2;
            color: white;
            border: none;
            padding: 18px;
            margin-bottom: 12px;
            border-radius: 10px;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: left;
            line-height: 1.4;
        }
        .choice-btn:hover {
            background: #357abd;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }
        .ending-btn {
            background: #27ae60;
            text-align: center;
            font-weight: bold;
            font-size: 1.2rem;
            color: white;
        }
        .ending-btn:hover {
            background: #2ecc71;
        }
        .hidden {
            display: none;
        }
    </style>
</head>
<body>

<div id="game-container">
    <div id="status-bar">
        <div class="stat-item">🕊️ 평화: <span id="stat-peace">0</span></div>
        <div class="stat-item">🌿 생태: <span id="stat-eco">0</span></div>
        <div class="stat-item">💰 경제: <span id="stat-economy">0</span></div>
    </div>

    <div id="progress">진행 중</div>
    <h2 id="story-title">게임을 준비 중입니다...</h2>
    <div id="story-text"></div>
    <div id="knowledge-box" class="hidden"></div>
    
    <div id="choices-container"></div>
</div>

